# ai-copilot-serve local settings
COPILOT_HOST=127.0.0.1
COPILOT_PORT=8765
SQLITE_PATH=./data/copilot.db
HERMES_HOME=~/.hermes
DEFAULT_GATEWAY_PORT=8642
# Space-separated command to start Hermes gateway (profile port injected via --port)
HERMES_GATEWAY_COMMAND=hermes gateway
LOG_DIR=./data/logs

# --- v1.2 Team tasks / workers (see docs/api-contract.md) ---
AIOS_TEAM_HUB_BASE_URL=
AIOS_TEAM_HUB_TOKEN=
AIOS_TEAM_HUB_USE_STUB=true
AIOS_DEVICE_ID=local-device
AIOS_AGENT_ID=hermes-local-agent
AIOS_TASK_POLL_INTERVAL_SECONDS=10
AIOS_RUN_EVENT_POLL_INTERVAL_SECONDS=2
AIOS_SYNC_OUTBOX_INTERVAL_SECONDS=5
AIOS_SYNC_OUTBOX_MAX_RETRIES=20
AIOS_TASK_REJECT_SETS_CANCELLED=false
# Optional JSON overrides for task type -> profile binding, e.g. {"coding_task":{"profile_type":"coding","require_approval":true}}
TASK_ROUTING_JSON=
