# smc-copilot-serve 环境变量示例
# 复制为 copilot-serve/.env：  cp .env.example .env

COPILOT_HOST=127.0.0.1
COPILOT_PORT=8765

# 与 smc-copilot-desktop 用户数据目录一致（代码默认值相同；可不写本行）
SQLITE_PATH=~/.hermes/desktop/sqlite.db
#
# 仅本地调试且希望库在仓库内时，可改为：SQLITE_PATH=./data/sqlite.db
# Electron Main spawn 建议 cwd=copilot-serve 根目录，并注入本变量或绝对路径
# （例如 Windows：%USERPROFILE%\.hermes\desktop\sqlite.db）

HERMES_HOME=~/.hermes
LOG_DIR=./data/logs
DEFAULT_GATEWAY_PORT=8642
AIOS_TEAM_HUB_USE_STUB=true

# Desktop V1.3 (optional)
# COPILOT_DESKTOP_TOKEN=
# COPILOT_REQUIRE_TOKEN=false
# CORS_ALLOW_ORIGINS=http://127.0.0.1,http://localhost
